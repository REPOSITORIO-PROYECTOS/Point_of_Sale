{
  "name": "point-of-sale-desktop",
  "version": "0.0.1",
  "private": true,
  "description": "Electron shell for Point of Sale",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron .",
    "dist:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "dist:win:fiscal": "npm run build && electron-builder --win --config electron-builder.fiscal.yml"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3"
  }
}
