HOST=127.0.0.1
PORT=58001
NODE_ENV=development
CORS_ORIGIN=http://localhost:58173
ENABLE_SWAGGER=true
APP_DATA_DIR=
SQLITE_DB_PATH=
AFIP_SERVICE_URL=http://127.0.0.1:58086
AFIP_PUNTO_VENTA=1
AFIP_PRODUCTION=false
AFIP_CUIT=
AFIP_CERT_PATH=
AFIP_KEY_PATH=
JWT_SECRET=dev-pos-jwt-secret-change-in-production
JWT_EXPIRES_IN=8h
DEV_SKIP_LICENSE=true
LICENSE_PUBLIC_KEY_PATH=
LICENSE_PRIVATE_KEY_PATH=
SUPPORT_RECOVERY_SECRET=
REMOTE_RELAY_URL=http://127.0.0.1:58090
REMOTE_ENABLED=true

# Publicar instalador / auto-update en GitHub Releases (opcional, solo dev local)
# electron-builder usa GH_TOKEN; el script de publish también acepta GITHUB_TOKEN.
GITHUB_TOKEN=
GH_UPDATER_TOKEN=

# En cada caja (.exe): NO usar backend/.env — copiar updater.env.example a:
#   %APPDATA%\PointOfSale\updater.env
# O ejecutar: scripts/deploy-updater-config.ps1 -Token ghp_...
