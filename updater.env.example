# Copiar a %APPDATA%\PointOfSale\updater.env en cada caja.
# O usar: scripts/deploy-updater-config.ps1 -Public
#
# Repo público (recomendado): no hace falta PAT en cada caja.
POS_UPDATER_PUBLIC_REPO=true

# Repo privado: descomentar y usar PAT con lectura de releases.
# POS_UPDATER_PUBLIC_REPO=false
# GH_UPDATER_TOKEN=ghp_REEMPLAZAR_CON_TU_TOKEN

# Desactivar actualizaciones en esta caja:
# POS_DISABLE_AUTO_UPDATE=true
