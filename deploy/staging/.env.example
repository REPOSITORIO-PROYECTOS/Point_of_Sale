# Staging POS web — copiar a deploy/staging/.env (no commitear)
# Uso: docker compose -f docker-compose.staging.yml --env-file deploy/staging/.env up -d --build

# Subdominios (deben coincidir con DNS y Caddyfile)
STAGING_LOCAL_A_HOST=local-a.tu-dominio.com
STAGING_LOCAL_B_HOST=local-b.tu-dominio.com

# CORS — usar los mismos hosts con https:// cuando Caddy termina TLS
STAGING_CORS_ORIGIN_A=https://local-a.tu-dominio.com
STAGING_CORS_ORIGIN_B=https://local-b.tu-dominio.com

# Secrets (generar valores únicos; nunca commitear)
STAGING_JWT_SECRET_A=cambiar-jwt-local-a-min-32-chars
STAGING_JWT_SECRET_B=cambiar-jwt-local-b-min-32-chars

# Licencia en staging (requiere STAGING=true en compose)
DEV_SKIP_LICENSE=true

# AFIP homologación (opcional; sin certificados la facturación fallará pero ventas/caja funcionan)
AFIP_PRODUCTION=false
AFIP_PUNTO_VENTA_A=1
AFIP_PUNTO_VENTA_B=2

# Swagger en staging (recomendado false si la API es accesible por internet)
ENABLE_SWAGGER=false
