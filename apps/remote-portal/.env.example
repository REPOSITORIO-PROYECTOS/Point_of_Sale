# Build-time (Vercel / Cloudflare Pages / CI)
# URL pública del relay (HTTPS). El WebSocket se deriva automáticamente (http→ws).
VITE_REMOTE_API_URL=https://relay.tu-dominio.com

# Opcional: solo si el WS no comparte host con la API
# VITE_REMOTE_WS_URL=wss://relay.tu-dominio.com

# Desarrollo local: dejar vacío — Vite proxy /api → :5090
